<Application
    x:Class="LightBulb.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:LightBulb.Views.Controls"
    xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
    xmlns:framework="clr-namespace:LightBulb.Framework"
    xmlns:materialAssists="clr-namespace:Material.Styles.Assists;assembly=Material.Styles"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:materialStyles="clr-namespace:Material.Styles.Themes;assembly=Material.Styles"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    xmlns:vm="clr-namespace:LightBulb.ViewModels"
    Name="LightBulb"
    ActualThemeVariantChanged="Application_OnActualThemeVariantChanged">
    <Application.DataTemplates>
        <framework:ViewManager />
    </Application.DataTemplates>

    <Application.Styles>
        <!--  This theme is used as a stub to pre-load default resources, the actual colors are set through code  -->
        <materialStyles:MaterialTheme
            BaseTheme="Light"
            PrimaryColor="Grey"
            SecondaryColor="DeepOrange" />
        <materialIcons:MaterialIconStyles />
        <dialogHostAvalonia:DialogHostStyles />

        <!--  Combo box  -->
        <Style Selector="ComboBox">
            <Setter Property="FontSize" Value="14" />

            <Style Selector="^ /template/ Panel#PART_RootPanel">
                <Setter Property="Height" Value="22" />
            </Style>

            <Style Selector="^ /template/ ToggleButton">
                <Style Selector="^:checked, ^:unchecked">
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="CornerRadius" Value="0" />

                    <Style Selector="^ ContentPresenter#contentPresenter">
                        <Setter Property="Margin" Value="12,8" />
                    </Style>
                </Style>
            </Style>
        </Style>

        <!--  Dialog host  -->
        <Style Selector="dialogHostAvalonia|DialogHost">
            <Setter Property="DialogMargin" Value="0" />
        </Style>

        <Style Selector="dialogHostAvalonia|DialogOverlayPopupHost">
            <Setter Property="Background" Value="{DynamicResource MaterialPaperBrush}" />
        </Style>

        <!--  Radio button  -->
        <Style Selector="RadioButton">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="materialAssists:SelectionControlAssist.Size" Value="18" />

            <Style Selector="^:checked, ^:unchecked">
                <Style Selector="^ /template/ Ellipse#PART_HoverEffect">
                    <Setter Property="Width" Value="32" />
                    <Setter Property="Height" Value="32" />
                </Style>
            </Style>
        </Style>

        <!--  Slider  -->
        <Style Selector="Slider">
            <Style Selector="^ /template/ ProgressBar#PART_ProgressLayer">
                <Style Selector="^:horizontal">
                    <Style Selector="^ Panel#PART_InnerPanel">
                        <Setter Property="Height" Value="2" />

                        <Style Selector="^ Border#PART_InactiveState">
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Height" Value="2" />
                        </Style>

                        <Style Selector="^ Border#PART_Indicator">
                            <Setter Property="Margin" Value="0" />
                        </Style>
                    </Style>
                </Style>
            </Style>

            <Style Selector="^ /template/ Track#PART_Track">
                <Style Selector="^:horizontal">
                    <Setter Property="Margin" Value="4,0" />
                </Style>

                <Style Selector="^ Border#PART_HoverEffect">
                    <Setter Property="Width" Value="24" />
                    <Setter Property="Height" Value="24" />
                </Style>

                <Style Selector="^ Border#PART_ThumbGrip">
                    <Setter Property="Width" Value="12" />
                    <Setter Property="Height" Value="12" />
                </Style>
            </Style>
        </Style>

        <!--  Text box  -->
        <Style Selector="TextBox">
            <Setter Property="FontSize" Value="14" />
        </Style>

        <!--  Toggle button  -->
        <Style Selector="ToggleButton">
            <Setter Property="TextElement.FontWeight" Value="Medium" />
        </Style>

        <!--  Toggle switch  -->
        <Style Selector="ToggleSwitch">
            <Setter Property="materialAssists:ToggleSwitchAssist.SwitchThumbOffBackground" Value="{DynamicResource ToggleBackgroundBrush}" />
        </Style>

        <!--  Tooltip  -->
        <Style Selector="ToolTip">
            <Setter Property="TextElement.FontSize" Value="14" />
            <Setter Property="TextElement.FontWeight" Value="Normal" />
            <Setter Property="TextElement.FontStyle" Value="Normal" />
            <Setter Property="TextElement.FontStretch" Value="Normal" />
        </Style>
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="ToggleBackgroundBrush" Color="#FFFFFF" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="ToggleBackgroundBrush" Color="#8E8E8E" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!--  Text box  -->
            <ControlTheme
                x:Key="CompactTextBox"
                BasedOn="{StaticResource {x:Type TextBox}}"
                TargetType="{x:Type TextBox}">
                <Styles>
                    <Style Selector="TextBox">
                        <Setter Property="Height" Value="22" />

                        <Style Selector="^ /template/ Panel#PART_TextFieldPanel">
                            <Setter Property="MinHeight" Value="0" />
                        </Style>

                        <Style Selector="^ /template/ Panel#PART_TextContainer">
                            <Setter Property="Margin" Value="0" />
                        </Style>
                    </Style>
                </Styles>
            </ControlTheme>
        </ResourceDictionary>
    </Application.Resources>

    <!--  Tray icon  -->
    <controls:TrayIcon.Icons>
        <controls:TrayIcon
            x:DataType="vm:MainViewModel"
            Command="{Binding ToggleWindowCommand}"
            DataContext="{DynamicResource MainViewModel}"
            Icon="/favicon.ico"
            ToolTipText="{Binding Dashboard.TrayTooltip}">
            <controls:NativeMenuItem
                Command="{Binding ToggleWindowCommand}"
                Header="{Binding LocalizationManager.TrayShowHideMenuItem}" />
            <controls:NativeMenuItem
                Command="{Binding ShowSettingsFromTrayCommand}"
                Header="{Binding LocalizationManager.TraySettingsMenuItem}" />
            <NativeMenuItemSeparator />
            <controls:NativeMenuItem
                Command="{Binding Dashboard.ToggleCommand}"
                Header="{Binding LocalizationManager.TrayToggleMenuItem}" />
            <controls:NativeMenuItem Header="{Binding LocalizationManager.TrayDisableMenuItem}">
                <controls:NativeMenuItem
                    Command="{Binding Dashboard.DisableUntilSunriseCommand}"
                    Header="{Binding LocalizationManager.TrayDisableUntilSunriseMenuItem}" />
                <controls:NativeMenuItem
                    Command="{Binding Dashboard.DisableTemporarilyCommand}"
                    Header="{Binding LocalizationManager.TrayDisableFor1DayMenuItem}">
                    <controls:NativeMenuItem.CommandParameter>
                        <sys:TimeSpan>1.00:00:00</sys:TimeSpan>
                    </controls:NativeMenuItem.CommandParameter>
                </controls:NativeMenuItem>
                <controls:NativeMenuItem
                    Command="{Binding Dashboard.DisableTemporarilyCommand}"
                    Header="{Binding LocalizationManager.TrayDisableFor12HoursMenuItem}">
                    <controls:NativeMenuItem.CommandParameter>
                        <sys:TimeSpan>0.12:00:00</sys:TimeSpan>
                    </controls:NativeMenuItem.CommandParameter>
                </controls:NativeMenuItem>
                <controls:NativeMenuItem
                    Command="{Binding Dashboard.DisableTemporarilyCommand}"
                    Header="{Binding LocalizationManager.TrayDisableFor6HoursMenuItem}">
                    <controls:NativeMenuItem.CommandParameter>
                        <sys:TimeSpan>0.06:00:00</sys:TimeSpan>
                    </controls:NativeMenuItem.CommandParameter>
                </controls:NativeMenuItem>
                <controls:NativeMenuItem
                    Command="{Binding Dashboard.DisableTemporarilyCommand}"
                    Header="{Binding LocalizationManager.TrayDisableFor3HoursMenuItem}">
                    <controls:NativeMenuItem.CommandParameter>
                        <sys:TimeSpan>0.03:00:00</sys:TimeSpan>
                    </controls:NativeMenuItem.CommandParameter>
                </controls:NativeMenuItem>
                <controls:NativeMenuItem
                    Command="{Binding Dashboard.DisableTemporarilyCommand}"
                    Header="{Binding LocalizationManager.TrayDisableFor1HourMenuItem}">
                    <controls:NativeMenuItem.CommandParameter>
                        <sys:TimeSpan>0.01:00:00</sys:TimeSpan>
                    </controls:NativeMenuItem.CommandParameter>
                </controls:NativeMenuItem>
                <controls:NativeMenuItem
                    Command="{Binding Dashboard.DisableTemporarilyCommand}"
                    Header="{Binding LocalizationManager.TrayDisableFor30MinutesMenuItem}">
                    <controls:NativeMenuItem.CommandParameter>
                        <sys:TimeSpan>0.00:30:00</sys:TimeSpan>
                    </controls:NativeMenuItem.CommandParameter>
                </controls:NativeMenuItem>
                <controls:NativeMenuItem
                    Command="{Binding Dashboard.DisableTemporarilyCommand}"
                    Header="{Binding LocalizationManager.TrayDisableFor15MinutesMenuItem}">
                    <controls:NativeMenuItem.CommandParameter>
                        <sys:TimeSpan>0.00:15:00</sys:TimeSpan>
                    </controls:NativeMenuItem.CommandParameter>
                </controls:NativeMenuItem>
                <controls:NativeMenuItem
                    Command="{Binding Dashboard.DisableTemporarilyCommand}"
                    Header="{Binding LocalizationManager.TrayDisableFor5MinutesMenuItem}">
                    <controls:NativeMenuItem.CommandParameter>
                        <sys:TimeSpan>0.00:05:00</sys:TimeSpan>
                    </controls:NativeMenuItem.CommandParameter>
                </controls:NativeMenuItem>
                <controls:NativeMenuItem
                    Command="{Binding Dashboard.DisableTemporarilyCommand}"
                    Header="{Binding LocalizationManager.TrayDisableFor1MinuteMenuItem}">
                    <controls:NativeMenuItem.CommandParameter>
                        <sys:TimeSpan>0.00:01:00</sys:TimeSpan>
                    </controls:NativeMenuItem.CommandParameter>
                </controls:NativeMenuItem>
            </controls:NativeMenuItem>
            <NativeMenuItemSeparator />
            <controls:NativeMenuItem
                Command="{Binding ExitCommand}"
                Header="{Binding LocalizationManager.TrayExitMenuItem}" />
        </controls:TrayIcon>
    </controls:TrayIcon.Icons>

</Application>