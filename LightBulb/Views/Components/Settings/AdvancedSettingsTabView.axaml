<UserControl
    x:Class="LightBulb.Views.Components.Settings.AdvancedSettingsTabView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:settings="clr-namespace:LightBulb.ViewModels.Components.Settings"
    x:DataType="settings:AdvancedSettingsTabViewModel">
    <StackPanel Margin="16" Orientation="Vertical">
        <!--  Theme  -->
        <DockPanel ToolTip.Tip="{Binding LocalizationManager.ThemeTooltip}">
            <ComboBox
                DockPanel.Dock="Right"
                ItemsSource="{Binding AvailableThemes}"
                SelectedItem="{Binding Theme}" />
            <TextBlock
                DockPanel.Dock="Left"
                Text="{Binding LocalizationManager.ThemeLabel}"
                TextTrimming="CharacterEllipsis" />
        </DockPanel>

        <!--  Language  -->
        <DockPanel Margin="0,16,0,0" ToolTip.Tip="{Binding LocalizationManager.LanguageTooltip}">
            <ComboBox DockPanel.Dock="Right" ItemsSource="{Binding AvailableLanguages}" SelectedItem="{Binding Language}" />
            <TextBlock
                DockPanel.Dock="Left"
                Text="{Binding LocalizationManager.LanguageLabel}"
                TextTrimming="CharacterEllipsis" />
        </DockPanel>

        <!--  Auto start  -->
        <DockPanel
            Margin="0,16,0,0"
            ToolTip.Tip="{Binding LocalizationManager.StartWithWindowsTooltip}">
            <ToggleSwitch DockPanel.Dock="Right" IsChecked="{Binding IsAutoStartEnabled}" />
            <TextBlock
                DockPanel.Dock="Left"
                Text="{Binding LocalizationManager.StartWithWindowsLabel}"
                TextTrimming="CharacterEllipsis" />
        </DockPanel>

        <!--  Auto update  -->
        <DockPanel
            Margin="0,16,0,0"
            ToolTip.Tip="{Binding LocalizationManager.AutoUpdateTooltip}">
            <ToggleSwitch DockPanel.Dock="Right" IsChecked="{Binding IsAutoUpdateEnabled}" />
            <TextBlock
                DockPanel.Dock="Left"
                Text="{Binding LocalizationManager.AutoUpdateLabel}"
                TextTrimming="CharacterEllipsis" />
        </DockPanel>

        <!--  Default to day time  -->
        <DockPanel
            Margin="0,16,0,0"
            ToolTip.Tip="{Binding LocalizationManager.DefaultToDayConfigTooltip}">
            <ToggleSwitch DockPanel.Dock="Right" IsChecked="{Binding IsDefaultToDayConfigurationEnabled}" />
            <TextBlock
                DockPanel.Dock="Left"
                Text="{Binding LocalizationManager.DefaultToDayConfigLabel}"
                TextTrimming="CharacterEllipsis" />
        </DockPanel>

        <!--  Pause when full screen  -->
        <DockPanel
            Margin="0,16,0,0"
            ToolTip.Tip="{Binding LocalizationManager.PauseWhenFullscreenTooltip}">
            <ToggleSwitch DockPanel.Dock="Right" IsChecked="{Binding IsPauseWhenFullScreenEnabled}" />
            <TextBlock
                DockPanel.Dock="Left"
                Text="{Binding LocalizationManager.PauseWhenFullscreenLabel}"
                TextTrimming="CharacterEllipsis" />
        </DockPanel>

        <!--  Configuration smoothing  -->
        <DockPanel
            Margin="0,16,0,0"
            ToolTip.Tip="{Binding LocalizationManager.GammaSmoothingTooltip}">
            <ToggleSwitch DockPanel.Dock="Right" IsChecked="{Binding IsConfigurationSmoothingEnabled}" />
            <TextBlock
                DockPanel.Dock="Left"
                Text="{Binding LocalizationManager.GammaSmoothingLabel}"
                TextTrimming="CharacterEllipsis" />
        </DockPanel>

        <!--  Gamma polling  -->
        <DockPanel
            Margin="0,16,0,0"
            ToolTip.Tip="{Binding LocalizationManager.GammaPollingTooltip}">
            <ToggleSwitch DockPanel.Dock="Right" IsChecked="{Binding IsGammaPollingEnabled}" />
            <TextBlock
                DockPanel.Dock="Left"
                Text="{Binding LocalizationManager.GammaPollingLabel}"
                TextTrimming="CharacterEllipsis" />
        </DockPanel>
    </StackPanel>
</UserControl>