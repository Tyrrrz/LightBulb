<UserControl
    x:Class="LightBulb.Views.Components.Settings.HotKeySettingsTabView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:LightBulb.Views.Controls"
    xmlns:settings="clr-namespace:LightBulb.ViewModels.Components.Settings"
    x:DataType="settings:HotKeySettingsTabViewModel">
    <StackPanel Margin="16" Orientation="Vertical">
        <!--  Toggle hotkey  -->
        <Grid ColumnDefinitions="*,Auto">
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="{Binding LocalizationManager.ToggleLightBulbHotkeyLabel}"
                TextTrimming="CharacterEllipsis"
                ToolTip.Tip="{Binding LocalizationManager.ToggleLightBulbHotkeyTooltip}" />
            <controls:HotKeyTextBox
                Grid.Column="1"
                Width="120"
                HotKey="{Binding ToggleHotKey}" />
        </Grid>

        <!--  Toggle window hotkey  -->
        <Grid Margin="0,16,0,0" ColumnDefinitions="*,Auto">
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="{Binding LocalizationManager.ToggleWindowLabel}"
                TextTrimming="CharacterEllipsis"
                ToolTip.Tip="{Binding LocalizationManager.ToggleWindowHotkeyTooltip}" />
            <controls:HotKeyTextBox
                Grid.Column="1"
                Width="120"
                HotKey="{Binding ToggleWindowHotKey}" />
        </Grid>

        <!--  Increase temperature offset hotkey  -->
        <Grid Margin="0,16,0,0" ColumnDefinitions="*,Auto">
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="{Binding LocalizationManager.IncreaseTemperatureOffsetLabel}"
                TextTrimming="CharacterEllipsis"
                ToolTip.Tip="{Binding LocalizationManager.IncreaseTemperatureOffsetTooltip}" />
            <controls:HotKeyTextBox
                Grid.Column="1"
                Width="120"
                HotKey="{Binding IncreaseTemperatureOffsetHotKey}" />
        </Grid>

        <!--  Decrease temperature offset hotkey  -->
        <Grid Margin="0,16,0,0" ColumnDefinitions="*,Auto">
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="{Binding LocalizationManager.DecreaseTemperatureOffsetLabel}"
                TextTrimming="CharacterEllipsis"
                ToolTip.Tip="{Binding LocalizationManager.DecreaseTemperatureOffsetTooltip}" />
            <controls:HotKeyTextBox
                Grid.Column="1"
                Width="120"
                HotKey="{Binding DecreaseTemperatureOffsetHotKey}" />
        </Grid>

        <!--  Increase brightness offset hotkey  -->
        <Grid Margin="0,16,0,0" ColumnDefinitions="*,Auto">
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="{Binding LocalizationManager.IncreaseBrightnessOffsetLabel}"
                TextTrimming="CharacterEllipsis"
                ToolTip.Tip="{Binding LocalizationManager.IncreaseBrightnessOffsetTooltip}" />
            <controls:HotKeyTextBox
                Grid.Column="1"
                Width="120"
                HotKey="{Binding IncreaseBrightnessOffsetHotKey}" />
        </Grid>

        <!--  Decrease brightness offset hotkey  -->
        <Grid Margin="0,16,0,0" ColumnDefinitions="*,Auto">
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="{Binding LocalizationManager.DecreaseBrightnessOffsetLabel}"
                TextTrimming="CharacterEllipsis"
                ToolTip.Tip="{Binding LocalizationManager.DecreaseBrightnessOffsetTooltip}" />
            <controls:HotKeyTextBox
                Grid.Column="1"
                Width="120"
                HotKey="{Binding DecreaseBrightnessOffsetHotKey}" />
        </Grid>

        <!--  Reset offset hotkey  -->
        <Grid Margin="0,16,0,0" ColumnDefinitions="*,Auto">
            <TextBlock
                Grid.Column="0"
                VerticalAlignment="Center"
                Text="{Binding LocalizationManager.ResetOffsetLabel}"
                TextTrimming="CharacterEllipsis"
                ToolTip.Tip="{Binding LocalizationManager.ResetOffsetHotkeyTooltip}" />
            <controls:HotKeyTextBox
                Grid.Column="1"
                Width="120"
                HotKey="{Binding ResetConfigurationOffsetHotKey}" />
        </Grid>
    </StackPanel>
</UserControl>